{
  "name": "@TMWAG/appsheroes-ui",
  "version": "0.1.3",
  "type": "module",
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git@github.com:TMWAG/appsheroes-ui.git"
  },
  "publishConfig": {
    "@TMWAG:registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./*": "./dist/*"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:ce",
    "build:lib": "vite build && vue-tsc -p tsconfig.lib.json && cp -r src/shared/styles dist/styles",
    "build:ce": "vite build -c vite.config.ce.ts",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "typecheck:lib": "vue-tsc -p tsconfig.lib.json --noEmit",
    "lint": "eslint . --fix --cache && steiger  ./src",
    "format": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.2.12",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-themes": "^10.2.12",
    "@storybook/addon-vitest": "^10.2.12",
    "@storybook/vue3-vite": "^10.2.12",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.3.23",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.2.7",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-storybook": "^10.2.12",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.0.1",
    "normalize.css": "^8.0.1",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.56.1",
    "prettier": "3.6.2",
    "sass": "^1.94.0",
    "steiger": "^0.5.11",
    "storybook": "^10.2.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.1"
  }
}
