{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "env.d.ts",
    "src/index.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.vue"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/__tests__/*"
  ]
}
